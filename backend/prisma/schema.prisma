generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             String @id @default(uuid())
  sku            String @unique
  name           String
  image          String?
  purchasePrice  Float
  salePrice      Float
  stock          Int
  minStock       Int
}